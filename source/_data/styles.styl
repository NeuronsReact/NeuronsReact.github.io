// Left-align post title and meta on post pages
.posts-expand .post-header {
  text-align: left;
  margin-bottom: 0px; //15px
}

.posts-expand .post-meta-container {
  text-align: left;
}

.posts-expand .post-meta {
  justify-content: flex-start;
}

// Left-align "Read more" button and post tags
.post-button {
  margin-top: 0px;
  margin-bottom: 42px; // 105px; // restore the original margin after removing the post divider line
  text-align: left;

  .btn {
    background: transparent;
    border: 0;
    color: var(--link-color);
    padding: 0;
    transition-property: color;

    &:hover {
      background: transparent;
      border: 0;
      color: var(--link-hover-color);
    }
  }
}

.posts-expand.index .post-body > :has(+ .post-button) {
  margin-bottom: 12px; // 真正撑开 Read more 上方距离的是摘要最后一个段落的默认下边距。现在只把首页/列表页里紧挨 Read more 前面的那个元素下边距压到 6px，不会影响文章正文页段落排版。
}

.posts-expand.index .post-block {
  cursor: pointer;
}

.posts-expand.index .post-block a,
.posts-expand.index .post-block button,
.posts-expand.index .post-block input,
.posts-expand.index .post-block select,
.posts-expand.index .post-block textarea,
.posts-expand.index .post-block label,
.posts-expand.index .post-block summary,
.posts-expand.index .post-block pre,
.posts-expand.index .post-block code {
  cursor: auto;
}

.post-tags {
  text-align: left;
}

.post-eof {
// Left-align the post divider line
//  margin-left: 0; 
//  margin-top: 15px;
  display: none;
}
