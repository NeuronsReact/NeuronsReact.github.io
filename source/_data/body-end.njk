<script>
document.addEventListener('click', event => {
  const interactiveSelector = [
    'a',
    'button',
    'input',
    'select',
    'textarea',
    'label',
    'summary',
    'pre',
    'code',
    '[role="button"]'
  ].join(',');

  if (event.defaultPrevented || event.button !== 0 || event.target.closest(interactiveSelector)) return;

  const postBlock = event.target.closest('.posts-expand.index .post-block');
  if (!postBlock) return;

  const selection = window.getSelection();
  if (selection && selection.toString()) return;

  const titleLink = postBlock.querySelector('.post-title-link');
  if (!titleLink) return;

  if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
    window.open(titleLink.href, '_blank', 'noopener');
    return;
  }

  window.location.assign(titleLink.href);
});
</script>
